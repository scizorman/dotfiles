{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make fmt)",
      "Bash(make check)",
      "Bash(make build)",
      "Bash(make diff)",
      "Bash(nix eval *)",
      "Bash(nix repl *)",
      "Bash(nvim --headless *)"
    ],
    "ask": [
      "Bash(make clean)",
      "Bash(make update)",
      "Bash(make test)",
      "Bash(make switch)"
    ]
  }
}
