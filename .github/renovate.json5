{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:best-practices"],
  ignorePresets: ["security:minimumReleaseAgeNpm"],
  automerge: true,
  labels: ["dependencies"],
  lockFileMaintenance: {
    enabled: true,
  },
  nix: {
    enabled: true,
  },
  packageRules: [
    {
      matchManagers: ["nix"],
      enabled: false,
    },
    {
      matchManagers: ["nix"],
      matchUpdateTypes: ["lockFileMaintenance"],
      enabled: true,
    },
  ],
  mise: {
    managerFilePatterns: ["modules/home/mise/config/config.toml"],
  },
}
