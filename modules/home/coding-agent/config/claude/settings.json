      "Bash(git fetch *)",
      "Bash(git -C * fetch *)",
      "Bash(git stash *)",
      "Bash(git -C * stash *)",
      "Bash(git add *)",
      "Bash(git -C * add *)",
      "Bash(git switch *)",
      "Bash(git -C * switch *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh issue status *)",
      "Bash(gh pr view *)",
