    "ask": [
      "Bash(gh issue close *)",
      "Bash(gh issue reopen *)",
      "Bash(gh pr close *)",
      "Bash(gh pr reopen *)",
      "Bash(gh pr review *)",
      "Bash(gh label create *)",
      "Bash(gh label edit *)",
      "Bash(gh run cancel *)",
      "Bash(gh run rerun *)",
      "Bash(gh workflow run *)"
