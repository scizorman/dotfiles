{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "DISABLE_AUTOUPDATER": "1"
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(realpath:*)",
      "Bash(readlink:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(jq:*)",
      "Bash(wc:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(whoami:*)",
      "Bash(uname:*)",
      "Bash(date:*)",
      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git stash:*)",
      "Bash(git add:*)",
      "Bash(git switch:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue status:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(gh run download:*)",
      "Bash(gh search:*)",
      "Bash(gh project list:*)",
      "Bash(gh project view:*)",
      "Bash(gh project field-list:*)",
      "Bash(gh project item-list:*)",
      "Bash(gh repo view:*)",
      "Bash(gh label list:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr ready:*)",
      "Bash(gh project item-add:*)",
      "Bash(gh project item-edit:*)",
      "Bash(gh project item-create:*)",
      "Bash(gh project item-archive:*)",
      "Bash(gh project field-create:*)",
      "Bash(gh project edit:*)",
      "Bash(gh project close:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Skill(git-operator)",
      "Skill(github-issue-creator)",
      "Skill(github-issue-commenter)",
      "Skill(github-pr-creator)",
      "Skill(github-sub-issue-creator)",
      "Skill(github-project-operator)",
      "Skill(github-project-reporter)",
      "Read(~/.claude/skills/**)",
      "Write(/tmp/*)"
    ],
    "deny": [
      "Bash(git commit --amend:*)",
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git rebase:*)",
      "Bash(git reset --hard:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh issue delete:*)",
      "Bash(gh issue transfer:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh repo archive:*)",
      "Bash(gh repo rename:*)",
      "Bash(gh repo create:*)",
      "Bash(gh release delete:*)",
      "Bash(gh project delete:*)",
      "Bash(gh project field-delete:*)",
      "Bash(gh project item-delete:*)",
      "Bash(gh label delete:*)",
      "Bash(gh run delete:*)",
      "Bash(gh secret:*)",
      "Bash(gh ssh-key:*)",
      "Bash(gh gpg-key:*)",
      "Bash(gh auth:*)",
      "Bash(cd:*)",
      "Bash(python -c:*)",
      "Bash(python3 -c:*)",
      "Bash(node -e:*)",
      "Bash(node --eval:*)",
      "Bash(node -p:*)",
      "Bash(node --print:*)"
    ],
    "ask": [
      "Bash(gh issue close:*)",
      "Bash(gh issue reopen:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr reopen:*)",
      "Bash(gh pr review:*)",
      "Bash(gh label create:*)",
      "Bash(gh label edit:*)",
      "Bash(gh run cancel:*)",
      "Bash(gh run rerun:*)",
      "Bash(gh workflow run:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git -C *)",
            "command": "echo 'Do not use git -C. Operate from the current working directory.' >&2; exit 2"
          }
        ]
      }
    ]
  },
  "model": "opusplan",
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "slack@claude-plugins-official": true,
    "cekernel@clonable-eden-plugins": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "clonable-eden-plugins": {
      "source": {
        "source": "github",
        "repo": "clonable-eden/plugins"
      }
    },
    "hashicorp": {
      "source": {
        "source": "github",
        "repo": "hashicorp/agent-skills"
      }
    }
  }
}
