      "Bash(git -C * commit --amend *)",
      "Bash(git push --force *)",
      "Bash(git -C * push --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git -C * push --force-with-lease *)",
      "Bash(git rebase *)",
      "Bash(git -C * rebase *)",
      "Bash(git reset --hard *)",
      "Bash(git -C * reset --hard *)",
      "Bash(git * --no-verify)",
      "Bash(git * --no-verify *)",
      "Bash(git * --no-gpg-sign)",
      "Bash(git * --no-gpg-sign *)",
      "Bash(git -c commit.gpgsign=false *)",
      "Bash(gh pr merge *)",
      "Bash(gh issue delete *)",
      "Bash(gh issue transfer *)",
      "Bash(gh repo delete *)",
