{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "DISABLE_AUTOUPDATER": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git switch:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Read(~/.claude/skills/**)",
      "Skill(git-operator)",
      "Skill(github-issue-creator)",
      "Skill(github-pr-creator)",
      "Skill(github-sub-issue-creator)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr comment:*)"
    ]
  },
  "model": "opusplan",
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "slack@claude-plugins-official": true,
    "cekernel@clonable-eden-plugins": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "clonable-eden-plugins": {
      "source": {
        "source": "github",
        "repo": "clonable-eden/plugins"
      }
    }
  }
}
