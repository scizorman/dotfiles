      "Bash(gh issue create *)",
      "Bash(gh issue comment *)",
      "Bash(gh issue edit *)",
      "Bash(gh pr create *)",
      "Bash(gh pr comment *)",
      "Bash(gh pr edit *)",
      "Bash(gh pr ready *)",
      "Bash(gh project item-add *)",
      "Bash(gh project item-edit *)",
      "Bash(gh project item-create *)",
      "Bash(gh project item-archive *)",
      "Bash(gh project field-create *)",
